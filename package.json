{
  "name": "tenderkz",
  "version": "0.1.0",
  "private": true,
  "description": "TenderKZ — платформа для победы в госзакупках РК",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:ai": "echo 'Use: cd apps/ai-service && uvicorn app.main:app --reload'",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "build:api": "npm run build --workspace=apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "db:push": "npm run db:push --workspace=apps/api",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
